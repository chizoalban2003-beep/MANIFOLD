{
  "$schema": "https://railway.app/railway.schema.json",
  "version": 2,
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "python -m manifold.server --port $PORT",
    "healthcheckPath": "/metrics",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
