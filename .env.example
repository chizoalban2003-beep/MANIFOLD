# OPTIONAL: set to enable bearer-token auth on protected endpoints (POST /shield, /b2b/handshake, /recruit).
# If unset, auth is disabled (suitable for local development only).
# If set but empty or whitespace, the server will refuse to start.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
MANIFOLD_API_KEY=your-secret-key-here

MANIFOLD_DB_URL=sqlite:///data/manifold.db
# For PostgreSQL: postgresql+asyncpg://user:pass@host/dbname
