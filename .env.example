# OPTIONAL: set to enable bearer-token auth on protected endpoints (POST /shield, /b2b/handshake, /recruit).
# If unset, auth is disabled (suitable for local development only).
# If set but empty or whitespace, the server will refuse to start.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
MANIFOLD_API_KEY=your-secret-key-here

MANIFOLD_DB_URL=sqlite:///data/manifold.db
# For PostgreSQL: postgresql+asyncpg://user:pass@host/dbname

# LLM upstream forwarding (optional — enables full proxy mode)
# If not set, MANIFOLD runs in governance-only mode
MANIFOLD_UPSTREAM_URL=https://api.openai.com/v1
MANIFOLD_UPSTREAM_KEY=sk-your-openai-key-here

# Multi-tenant org registry persistence (optional — defaults to orgs.json in cwd)
MANIFOLD_ORGS_FILE=data/orgs.json

# HTTP server port (used by `web:` Procfile process; Heroku/Fly set PORT automatically)
PORT=8080

# Streamlit dashboard port (used by `dashboard:` Procfile process)
DASHBOARD_PORT=8501
