  },
  "homepage": "https://github.com/chizoalban2003-beep/MANIFOLD#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.4.0"
  }
}
